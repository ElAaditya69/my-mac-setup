#!/usr/bin/env sh

# Window Borders Configuration
yabai -m config window_border on
yabai -m config window_border_width 4
yabai -m config active_window_border_color 0xffbd93f9
yabai -m config normal_window_border_color 0xff44475a
yabai -m config insert_feedback_color 0xff6272a4

# Window Border Styling Marks
yabai -m config window_border on
yabai -m config window_border_width 4
yabai -m config active_window_border_color 0xffbd93f9
yabai -m config normal_window_border_color 0x00000000

# Restore the beautiful purple-pink window borders
yabai -m config window_border on
yabai -m config window_border_width 3
yabai -m config active_window_border_color 0xffbd93f9
yabai -m config normal_window_border_color 0x00000000

echo "yabai configuration loaded.."
