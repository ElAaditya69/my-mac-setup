font_family JetBrainsMono NF
font_size 13.0

# Set a rich dark charcoal base color
background #1a1a1a

# Tighten transparency so background text doesn't bleed through heavily
background_opacity 0.45

# Turn off the native macOS blur filter which causes that gray smudge look
background_blur 20

window_padding_width 24

confirm_os_window_close 0

hide_window_decorations no




